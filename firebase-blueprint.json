{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["master", "admin", "seller", "unassigned"] },
        "agencyId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Agency": {
      "title": "Agency",
      "description": "Agency details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/agencies/{agencyId}": {
      "schema": { "$ref": "#/entities/Agency" },
      "description": "Agencies"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks"
    },
    "/vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Vehicles"
    },
    "/vehicleExpenses/{expenseId}": {
      "schema": "VehicleExpense",
      "description": "Vehicle Expenses"
    },
    "/deals/{dealId}": {
      "schema": "Deal",
      "description": "Deals"
    },
    "/files/{fileId}": {
      "schema": "File",
      "description": "Files"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Notes"
    },
    "/agency_tags/{tagId}": {
      "schema": "AgencyTag",
      "description": "Agency Tags"
    }
  }
}
