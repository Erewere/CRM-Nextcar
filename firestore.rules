rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserDoc(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userExists() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserAgencyId() {
      return userExists() ? getUserData().agencyId : null;
    }

    function isMaster() {
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email == 'luisfj@gmail.com') ||
        (userExists() && getUserData().role == 'master')
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isMaster() ||
        (userExists() && getUserData().role == 'admin')
      );
    }

    function isSameAgency(agencyId) {
      return isMaster() || (isAuthenticated() && agencyId != null && getUserAgencyId() == agencyId);
    }

    // AGENCIES
    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isMaster() || (isAdmin() && isSameAgency(agencyId));
      allow delete: if isMaster();
    }

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isUserDoc(userId);
      allow update: if isAuthenticated() && (isUserDoc(userId) || isMaster() || isAdmin());
      allow delete: if isMaster() || (isAdmin() && resource.data.agencyId == getUserAgencyId());
    }

    // CLIENTS
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow public leads / forms & authenticated users
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // TASKS
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // DEALS
    match /deals/{dealId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // VEHICLES
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // VEHICLE EXPENSES
    match /vehicleExpenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // NOTES
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // FILES
    match /files/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // AGENCY TAGS
    match /agency_tags/{tagId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // AGENCY CHATS
    match /agencyChats/{chatId} {
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Default catch-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
